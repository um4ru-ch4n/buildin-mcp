# Transport mode: stdio (local) or http (remote, multi-tenant)
TRANSPORT_MODE=stdio

# Required for stdio mode. For http mode, token comes from client URL query param.
BUILDIN_BOT_TOKEN=your_bot_token_here

# HTTP mode settings
HTTP_PORT=3000

# Optional: Log level (debug, info, warn, error). Default: info
LOG_LEVEL=info

# Optional: Node environment (development, production). Default: production
NODE_ENV=production
